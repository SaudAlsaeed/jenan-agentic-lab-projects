{
  "name": "jenan-agentic-lab-projects",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for all Jenan-agentic-lab Multica projects",
  "scripts": {
    "dev:jenan-lab-hub:web": "pnpm --filter @jenan-lab-hub/web dev",
    "dev:jenan-lab-hub:api": "pnpm --filter @jenan-lab-hub/api dev",
