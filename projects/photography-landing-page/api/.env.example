# Environment sample for Photography Landing Page API
# Copy to `.env` and fill real values. Never commit `.env`.

PORT=3002

# SQLite file path (default: ./data/inquiries.sqlite)
# DATABASE_PATH=

# Telegram Bot API — keep server-side only (R-08)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin auth — JWT Bearer tokens (documented choice for JEN-11)
ADMIN_JWT_SECRET=replace-with-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# ADMIN_TOKEN_TTL=8h

# Optional CORS origin (default: reflect request origin / allow all in dev)
# CORS_ORIGIN=http://localhost:5173
